{
    "version": 2,
    "builds": [
      {
        "src": "app/wsgi.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "15mb" }
      },
      {
        "src": "app/staticfiles/**/*",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/static/(.*)",
        "dest": "/staticfiles/$1"
      },
      {
        "src": "/(.*)",
        "dest": "app/wsgi.py"
      }
    ],
    "build": {
      "env": {
        "DJANGO_COLLECTSTATIC": "true"
      },
      "commands": {
        "build": [
          "python manage.py collectstatic --noinput",
          "python manage.py migrate --noinput"
        ]
      }
    }
  }
  